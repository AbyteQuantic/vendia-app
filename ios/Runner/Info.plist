<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Permite HTTP cleartext para desarrollo local (backend en red WiFi) -->
	<!-- Cámara: escaneo de códigos de barras y captura de facturas/productos
	     (mobile_scanner + image_picker). Sin esta clave iOS cierra la app
	     al primer acceso a la cámara. -->
	<key>NSCameraUsageDescription</key>
	<string>VendIA usa la cámara para escanear los códigos de barras de sus productos y tomar fotos de sus facturas.</string>
	<!-- Galería de fotos: seleccionar imágenes de productos o facturas ya
	     guardadas en el teléfono (image_picker + image_cropper). -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>VendIA accede a sus fotos para que pueda elegir imágenes de sus productos o facturas desde la galería.</string>
	<!-- Permiso de ubicación GPS -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>VendIA necesita su ubicación para encontrar la dirección de su negocio automáticamente.</string>
	<!-- Inventario por voz: grabación del audio que se manda a Gemini -->
	<key>NSMicrophoneUsageDescription</key>
	<string>VendIA usa el micrófono para que dictes los productos que llegaron y los registre por ti.</string>
	<!-- Bluetooth térmico: impresora de recibos + cajón monedero. -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>VendIA conecta con su impresora térmica para imprimir recibos.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>VendIA conecta con su impresora térmica para imprimir recibos.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>VendIA</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>vendia_pos</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<!-- Spec 086 — iconos alternos por temporada (pre-empaquetados; el primario
	     sigue en Assets.xcassets/AppIcon). iOS muestra una alerta al cambiar el
	     icono -> se cambia 1 vez por temporada en cold-start. iOS 10.3+. -->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>navidad</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-navidad</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>mundial</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-mundial</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_mujer</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_mujer</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_madre</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_madre</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_padre</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_padre</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>CFBundleIcons~ipad</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>navidad</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-navidad</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>mundial</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-mundial</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_mujer</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_mujer</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_madre</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_madre</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>dia_padre</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-dia_padre</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
