<?xml version="1.0" encoding="utf-8"?>
<!--
  Permite HTTP cleartext a IPs de red local para desarrollo.
  - 10.0.2.2: host Mac desde el emulador Android
  - 192.168.0.0/16: rango típico de redes WiFi locales
  En producción el backend usa HTTPS (Cloud Run), así que esto no afecta prod.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
    </domain-config>
</network-security-config>
