<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permiso de internet (requerido para llamadas al backend) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Permisos de ubicación (GPS para dirección del negocio) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Inventario por voz: grabación del audio que se manda a Gemini -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Bluetooth térmico: impresora de recibos + cajón monedero. -->
    <!-- Legacy permissions (Android <= 11). -->
    <uses-permission android:name="android.permission.BLUETOOTH"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"/>
    <!-- Android 12+ runtime permissions. We never derive physical
         location from the BLE scan, so we tag neverForLocation to
         avoid the location-runtime-permission popup on S+. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"/>
    <!-- ACCESS_FINE_LOCATION is already declared above for GPS dirección,
         and that one has no maxSdkVersion (we keep using GPS in 12+).
         Bluetooth on Android <= 11 reuses the same permission. -->

    <!-- Bank notification listener: reads only the title/text of
         notifications posted by the bank/wallet apps in the listener
         allowlist. Required so the cashier can opt in via "Acceso a
         notificaciones" in system settings — there is no runtime
         permission API for this; the manifest declaration alone is
         enough for the system to surface the toggle. -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"/>

    <!-- Impresora térmica por USB (SAT N140 all-in-one + DigitalPOS DIG-E200I).
         required=false para que el APK siga instalándose en equipos sin USB
         host (teléfonos de los tenderos, web). El permiso USB es en runtime
         (UsbManager); el intent-filter + device_filter de abajo lo auto-conceden
         al conectar la impresora para una experiencia "conectar y usar". -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false"/>

    <application
        android:label="VendIA"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- USB printer auto-attach: cuando se conecta una impresora USB
                 que matchea res/xml/device_filter.xml, el sistema concede el
                 permiso USB sin popup y abre la app (connect & use). -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"/>
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter"/>
        </activity>

        <!-- Spec 086 — branding estacional: cambio de ícono nativo sin store
             release (flutter_dynamic_icon_plus). MainActivity SIGUE siendo el
             ícono por defecto (conserva su LAUNCHER + el USB_DEVICE_ATTACHED de
             la impresora ESC/POS — NO se toca). Cada temporada es un
             activity-alias adicional, deshabilitado por defecto; el plugin lo
             habilita en cold-start cuando icon_variant lo pide. Para agregar una
             temporada nueva: pre-empaquetar sus mipmaps + un activity-alias aquí
             con android:name=".<variant>" (debe coincidir con seasonal_icons.dart). -->
        <service
            android:name="com.solusibejo.flutter_dynamic_icon_plus.FlutterDynamicIconPlusService"
            android:stopWithTask="false"/>

        <activity-alias
            android:label="VendIA"
            android:icon="@mipmap/ic_launcher_navidad"
            android:roundIcon="@mipmap/ic_launcher_navidad"
            android:name=".navidad"
            android:exported="true"
            android:enabled="false"
            android:targetActivity=".MainActivity">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:label="VendIA"
            android:icon="@mipmap/ic_launcher_mundial"
            android:roundIcon="@mipmap/ic_launcher_mundial"
            android:name=".mundial"
            android:exported="true"
            android:enabled="false"
            android:targetActivity=".MainActivity">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:label="VendIA"
            android:icon="@mipmap/ic_launcher_dia_mujer"
            android:roundIcon="@mipmap/ic_launcher_dia_mujer"
            android:name=".dia_mujer"
            android:exported="true"
            android:enabled="false"
            android:targetActivity=".MainActivity">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:label="VendIA"
            android:icon="@mipmap/ic_launcher_dia_madre"
            android:roundIcon="@mipmap/ic_launcher_dia_madre"
            android:name=".dia_madre"
            android:exported="true"
            android:enabled="false"
            android:targetActivity=".MainActivity">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:label="VendIA"
            android:icon="@mipmap/ic_launcher_dia_padre"
            android:roundIcon="@mipmap/ic_launcher_dia_padre"
            android:name=".dia_padre"
            android:exported="true"
            android:enabled="false"
            android:targetActivity=".MainActivity">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <!-- image_cropper (uCrop) — required so the QR cropper screen
             can launch from the payment-methods upload flow. The
             AppCompat.Light.NoActionBar theme is the default that
             image_cropper recommends and matches the rest of the
             modal screens we already use. -->
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>

        <!-- Bank-notification listener (Mandatory Image Receipts epic).
             Purely informative — fires a green SnackBar on the active
             checkout flow when a bank app posts a notification. Never
             gates UI; the cashier still must attach the receipt photo
             to enable "Confirmar pago". The android:permission below
             tells the system to bind us via a privileged channel, and
             the intent-filter is the canonical action that exposes
             this service to the "Notification access" toggle in
             Settings → Privacidad → Acceso a notificaciones. -->
        <service
            android:name=".BankNotificationListener"
            android:exported="true"
            android:label="VendIA · Notificaciones bancarias"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher needs these declared on Android 11+ (targetSdk 30+) to
             resolve WhatsApp (https), SMS (sms:), email (mailto:) and tel. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="http"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="sms"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="sms"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
    </queries>
</manifest>
