# ============================================================
# VendIA - Variables de Entorno
# ============================================================
#
# INSTRUCCIONES:
# 1. Duplica este archivo y renómbralo a ".env"
#    $ cp .env.example .env
#
# 2. Reemplaza <IP_DE_LA_MAC> por la IP local de tu Mac.
#    Para encontrarla, abre Terminal y ejecuta:
#    $ ipconfig getifaddr en0
#    Ejemplo: si tu IP es 192.168.1.15, la línea quedaría:
#    API_BASE_URL=http://192.168.1.15:8080/api/v1
#
# 3. Asegúrate de que el backend Docker esté corriendo:
#    $ docker compose up -d
#
# NOTA: NO subas el archivo .env a git (ya está en .gitignore).
# ============================================================

API_BASE_URL=http://<IP_DE_LA_MAC>:8089/api/v1
