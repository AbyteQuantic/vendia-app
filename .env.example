# ============================================================
# VendIA - Variables de Entorno
# ============================================================
#
# Duplica este archivo y renómbralo a ".env"
#    $ cp .env.example .env
#
# Producción:
#    API_BASE_URL=https://vendia-api.onrender.com
#
# Desarrollo local:
#    API_BASE_URL=http://<IP_DE_LA_MAC>:8089/api/v1
#
# NOTA: NO subas el archivo .env a git (ya está en .gitignore).
# ============================================================

API_BASE_URL=https://vendia-api.onrender.com
